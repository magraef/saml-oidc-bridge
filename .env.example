# OIDC Configuration
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URL=https://saml-bridge.example.com/oidc/callback
OIDC_SCOPES=openid,profile,email

# SAML IdP Configuration
SAML_ENTITY_ID=https://saml-bridge.example.com/metadata
SAML_ACS_URL=https://saml-bridge.example.com/saml/login
SAML_CERTIFICATE_PATH=/certs/tls.crt
SAML_PRIVATE_KEY_PATH=/certs/tls.key

# Service Provider Configuration
SP_ENTITY_ID=https://your-app.example.com/saml/metadata
SP_ACS_URL=https://your-app.example.com/saml/acs

# Attribute Mapping
MAPPING_NAME_ID=email

# Session Configuration
SESSION_COOKIE_SECRET=your-random-secret-key-here
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_NAME=saml-oidc-bridge-session

# Server Configuration
SERVER_ADDRESS=:8080
DEBUG=false

# Storage Configuration
STORAGE_DATABASE_PATH=/data/saml-oidc-bridge.db
# IMPORTANT: Generate a secure 32-byte (64 hex characters) encryption key for production
# Example: openssl rand -hex 32
# STORAGE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
