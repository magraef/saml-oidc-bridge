# SAML OAuth Proxy Configuration
# Copy this file to .env and adjust the values
# All settings are configured via environment variables

# OpenID Connect Provider Configuration
# OIDC provider's issuer URL (e.g., https://accounts.google.com, https://login.microsoftonline.com/tenant-id/v2.0)
OIDC_ISSUER_URL=https://idp.example.com

# OAuth2 client credentials
OIDC_CLIENT_ID=my-client-id
OIDC_CLIENT_SECRET=my-client-secret

# Redirect URL where OIDC provider sends the user after authentication
# Must match the redirect URI registered with your OIDC provider
OIDC_REDIRECT_URL=https://proxy.example.com/oidc/callback

# OAuth2 scopes to request (comma-separated)
# openid is required, add profile and email for user information
# Default: openid,profile,email
OIDC_SCOPES=openid,profile,email

# SAML Identity Provider Configuration (this proxy)
# Entity ID for this SAML IdP
SAML_ENTITY_ID=https://proxy.example.com/metadata

# Assertion Consumer Service URL (where SP sends AuthnRequests)
SAML_ACS_URL=https://proxy.example.com/saml/login

# Certificate Configuration (OPTIONAL)
# If both paths are omitted, a self-signed certificate will be auto-generated (for development only)
# For production, provide both certificate and private key paths

# Path to X.509 certificate (PEM format) - OPTIONAL
# If not set, a self-signed certificate will be generated automatically
# SAML_CERTIFICATE_PATH=/certs/tls.crt

# Path to private key (PEM format) - OPTIONAL
# If not set, a self-signed certificate will be generated automatically
# SAML_PRIVATE_KEY_PATH=/certs/tls.key

# Service Provider Configuration (your application)
# Entity ID of the SAML Service Provider
SP_ENTITY_ID=https://my-app.example.com/saml/metadata

# Assertion Consumer Service URL of the SP (where we send SAML responses)
SP_ACS_URL=https://my-app.example.com/saml/acs

# Claim/Attribute Mapping
# OIDC claim to use as SAML NameID
# Common values: email, sub, preferred_username
MAPPING_NAME_ID=email

# Map OIDC claims to SAML attributes (JSON format)
# Format: {"saml_attribute_name":"oidc_claim_name"}
# Example: MAPPING_ATTRIBUTES={"email":"email","username":"preferred_username","displayName":"name"}
# Note: This is optional and can be left empty if no attribute mapping is needed
MAPPING_ATTRIBUTES=

# Session Configuration
# Secret key for signing session cookies (change this!)
# Generate with: openssl rand -base64 32
SESSION_COOKIE_SECRET=CHANGE-ME-TO-A-RANDOM-SECRET-KEY

# Use secure cookies (requires HTTPS)
# Default: false
SESSION_COOKIE_SECURE=true

# Cookie name
# Default: saml-oidc-bridge-session
SESSION_COOKIE_NAME=saml-oidc-bridge-session

# HTTP Server Configuration
# Address to listen on
# Use :8080 for all interfaces, localhost:8080 for local only
# Default: :8080
SERVER_ADDRESS=:8080

# Port to listen on (alternative to SERVER_ADDRESS)
# If set, overrides the port in SERVER_ADDRESS
# PORT=8080

# Enable debug logging
# Default: false
DEBUG=false

# Storage Configuration
# Path to SQLite database file
# Default: ./saml-oidc-bridge.db
STORAGE_DATABASE_PATH=./saml-oidc-bridge.db